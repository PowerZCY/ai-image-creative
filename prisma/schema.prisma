generator client {
  provider   = "prisma-client"
  output     = "../src/generated/prisma"
  engineType = "client"
}

datasource db {
  provider = "postgresql"
  schemas  = ["monica_ai", "public"]
}

// === backend-core models ===
model User {
  id              BigInt           @id @default(autoincrement())
  userId          String           @unique @default(dbgenerated("gen_random_uuid()")) @map("user_id") @db.Uuid
  status          String           @default("anonymous") @db.VarChar(50)
  fingerprintId   String?          @map("fingerprint_id") @db.VarChar(255)
  clerkUserId     String?          @unique @map("clerk_user_id") @db.VarChar(255)
  stripeCusId     String?          @unique @map("stripe_cus_id") @db.VarChar(255)
  email           String?          @db.VarChar(255)
  userName        String?          @map("user_name") @db.VarChar(255)
  createdAt       DateTime?        @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime?        @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  sourceRef       Json?            @map("source_ref")
  creditAuditLogs CreditAuditLog[]
  credit          Credit?
  subscription    Subscription?
  transactions    Transaction[]

  @@index([fingerprintId], map: "idx_users_fingerprint_id")
  @@map("users")
  @@schema("monica_ai")
}

model Subscription {
  id                BigInt    @id @default(autoincrement())
  userId            String    @unique @map("user_id") @db.Uuid
  status            String    @default("incomplete") @db.VarChar(50)
  paySubscriptionId String?   @map("pay_subscription_id") @db.VarChar(255)
  orderId           String?   @map("order_id") @db.VarChar(255)
  priceId           String?   @map("price_id") @db.VarChar(255)
  priceName         String?   @map("price_name") @db.VarChar(255)
  creditsAllocated  Int       @default(0) @map("credits_allocated")
  subPeriodStart    DateTime? @map("sub_period_start") @db.Timestamptz(6)
  subPeriodEnd      DateTime? @map("sub_period_end") @db.Timestamptz(6)
  createdAt         DateTime? @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime? @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  deleted           Int       @default(0)
  user              User      @relation(fields: [userId], references: [userId], onDelete: NoAction, onUpdate: NoAction)

  @@index([paySubscriptionId], map: "idx_subscriptions_pay_subscription_id")
  @@index([orderId], map: "idx_subscriptions_order_id")
  @@map("subscriptions")
  @@schema("monica_ai")
}

model Credit {
  id     BigInt @id @default(autoincrement())
  userId String @unique @map("user_id") @db.Uuid

  // ===== Free =====
  balanceFree    Int       @default(0) @map("balance_free")
  totalFreeLimit Int       @default(0) @map("total_free_limit")
  freeStart      DateTime? @map("free_start") @db.Timestamptz(6)
  freeEnd        DateTime? @map("free_end") @db.Timestamptz(6)

  // ===== Subscription =====
  balancePaid    Int       @default(0) @map("balance_paid")
  totalPaidLimit Int       @default(0) @map("total_paid_limit")
  paidStart      DateTime? @map("paid_start") @db.Timestamptz(6)
  paidEnd        DateTime? @map("paid_end") @db.Timestamptz(6)

  // ===== OneTimePaid =====
  balanceOneTimePaid    Int       @default(0) @map("balance_onetime_paid")
  totalOneTimePaidLimit Int       @default(0) @map("total_onetime_paid_limit")
  oneTimePaidStart      DateTime? @map("onetime_paid_start") @db.Timestamptz(6)
  oneTimePaidEnd        DateTime? @map("onetime_paid_end") @db.Timestamptz(6)

  createdAt DateTime? @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime? @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  user      User      @relation(fields: [userId], references: [userId], onDelete: NoAction, onUpdate: NoAction)

  @@index([userId], map: "idx_credits_user_id")
  @@map("credits")
  @@schema("monica_ai")
}

model Transaction {
  id                    BigInt    @id @default(autoincrement())
  userId                String    @map("user_id") @db.Uuid
  orderId               String    @unique @map("order_id") @db.VarChar(255)
  orderStatus           String    @default("created") @map("order_status") @db.VarChar(50)
  orderCreatedAt        DateTime? @default(now()) @map("order_created_at") @db.Timestamptz(6)
  orderExpiredAt        DateTime? @map("order_expired_at") @db.Timestamptz(6)
  orderUpdatedAt        DateTime? @default(now()) @updatedAt @map("order_updated_at") @db.Timestamptz(6)
  type                  String?   @db.VarChar(50)
  paySupplier           String?   @map("pay_supplier") @db.VarChar(255)
  paySessionId          String?   @map("pay_session_id") @db.VarChar(255)
  payTransactionId      String?   @unique @map("pay_transaction_id") @db.VarChar(255)
  paySubscriptionId     String?   @map("pay_subscription_id") @db.VarChar(255)
  subPeriodStart        DateTime? @map("sub_period_start") @db.Timestamptz(6)
  subPeriodEnd          DateTime? @map("sub_period_end") @db.Timestamptz(6)
  subLastTryCancelAt    DateTime? @map("sub_last_try_cancel_at") @db.Timestamptz(6)
  subPeriodCanceledAt   DateTime? @map("sub_period_canceled_at") @db.Timestamptz(6)
  subCancellationDetail String?   @map("sub_cancellation_detail") @db.Text
  priceId               String?   @map("price_id") @db.VarChar(255)
  priceName             String?   @map("price_name") @db.VarChar(255)
  amount                Decimal?  @db.Decimal(10, 2)
  currency              String?   @db.VarChar(50)
  creditsGranted        Int?      @default(0) @map("credits_granted")
  payInvoiceId          String?   @map("pay_invoice_id") @db.VarChar(255)
  paymentStatus         String    @default("un_paid") @map("payment_status") @db.VarChar(50)
  billingReason         String?   @map("billing_reason") @db.VarChar(100)
  hostedInvoiceUrl      String?   @map("hosted_invoice_url") @db.Text
  invoicePdf            String?   @map("invoice_pdf") @db.Text
  orderDetail           String?   @map("order_detail")
  paidEmail             String?   @map("paid_email") @db.VarChar(255)
  paidAt                DateTime? @map("paid_at") @db.Timestamptz(6)
  paidDetail            String?   @map("paid_detail")
  payUpdatedAt          DateTime? @map("pay_updated_at") @db.Timestamptz(6)
  deleted               Int       @default(0)
  user                  User      @relation(fields: [userId], references: [userId], onDelete: NoAction, onUpdate: NoAction)

  @@index([orderId], map: "idx_transactions_order_id")
  @@index([paySubscriptionId], map: "idx_transactions_pay_subscription_id")
  @@index([userId], map: "idx_transactions_user_id")
  @@map("transactions")
  @@schema("monica_ai")
}

model CreditAuditLog {
  id               BigInt    @id @default(autoincrement())
  userId           String    @map("user_id") @db.Uuid
  creditsChange    Int       @map("credits_change")
  feature          String?   @db.VarChar(255)
  creditType       String    @map("credit_type") @db.VarChar(50)
  operationType    String    @map("operation_type") @db.VarChar(100)
  operationReferId String?   @map("operation_refer_id") @db.VarChar(255)
  createdAt        DateTime? @default(now()) @map("created_at") @db.Timestamptz(6)
  deleted          Int       @default(0)
  user             User      @relation(fields: [userId], references: [userId], onDelete: NoAction, onUpdate: NoAction)

  @@index([creditType], map: "idx_credit_audit_log_credit_type")
  @@index([operationType], map: "idx_credit_audit_log_operation_type")
  @@index([userId], map: "idx_credit_audit_log_user_id")
  @@map("credit_audit_log")
  @@schema("monica_ai")
}

model UserBackup {
  id             BigInt    @id @default(autoincrement())
  originalUserId String    @map("original_user_id") @db.Uuid
  status         String?   @db.VarChar(50)
  fingerprintId  String?   @map("fingerprint_id") @db.VarChar(255)
  clerkUserId    String?   @map("clerk_user_id") @db.VarChar(255)
  stripeCusId    String?   @map("stripe_cus_id") @db.VarChar(255)
  email          String?   @db.VarChar(255)
  userName       String?   @map("user_name") @db.VarChar(255)
  backupData     Json?     @map("backup_data")
  deletedAt      DateTime? @default(now()) @map("deleted_at") @db.Timestamptz(6)
  createdAt      DateTime? @default(now()) @map("created_at") @db.Timestamptz(6)
  deleted        Int       @default(0)

  @@index([clerkUserId], map: "idx_user_backup_clerk_user_id")
  @@index([email], map: "idx_user_backup_email")
  @@index([fingerprintId], map: "idx_user_backup_fingerprint_id")
  @@index([originalUserId], map: "idx_user_backup_original_user_id")
  @@map("user_backup")
  @@schema("monica_ai")
}

model Apilog {
  id         BigInt    @id @default(autoincrement())
  apiType    String    @map("api_type") @db.VarChar(100)
  methodName String    @map("method_name") @db.VarChar(255)
  summary    String?
  request    String?
  response   String?
  createdAt  DateTime? @default(now()) @map("created_at") @db.Timestamptz(6)

  @@map("apilog")
  @@schema("monica_ai")
}

model ThemeSubmission {
  id           BigInt    @id @default(autoincrement())
  userId       String    @map("user_id") @db.Uuid
  status       String    @default("under_review") @db.VarChar(50)
  title        String    @db.VarChar(255)
  details      String    @db.Text
  submitReason String?   @map("submit_reason") @db.Text
  reviewFlow   Json?     @map("review_flow")
  submittedAt  DateTime? @default(now()) @map("submitted_at") @db.Timestamptz(6)
  createdAt    DateTime? @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime? @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  deleted      Int       @default(0)

  @@index([userId, submittedAt], map: "idx_theme_submissions_user_submitted_at")
  @@index([status, submittedAt], map: "idx_theme_submissions_status_submitted_at")
  @@map("theme_submissions")
  @@schema("monica_ai")
}

model Theme {
  id                 BigInt    @id @default(autoincrement())
  title              String    @db.VarChar(255)
  brief              String?   @db.Text
  themeNote          String?   @map("theme_note") @db.Text
  publishDate        DateTime? @map("publish_date") @db.Date
  coverImageUrl      String?   @map("cover_image_url") @db.Text
  featuredImageIds   BigInt[]  @default([]) @map("featured_image_ids")
  generatorIdeas     String[]  @default([]) @map("generator_ideas")
  avoidCliches       String[]  @default([]) @map("avoid_cliches")
  tags               Json?
  seoTitle           String?   @map("seo_title") @db.VarChar(255)
  seoMetaDescription String?   @map("seo_meta_description") @db.Text
  seoKeywords        String[]  @default([]) @map("seo_keywords")
  imageSeoNotes      Json?     @map("image_seo_notes")
  stats              Json?
  sourceType         String?   @map("source_type") @db.VarChar(50)
  sourceSubmissionId BigInt?   @map("source_submission_id")
  createdAt          DateTime? @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt          DateTime? @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  deleted            Int       @default(0)

  @@index([publishDate], map: "idx_themes_publish_date")
  @@index([sourceSubmissionId], map: "idx_themes_source_submission_id")
  @@map("themes")
  @@schema("monica_ai")
}

model ReferenceImage {
  id             BigInt    @id @default(autoincrement())
  referenceId    String    @unique @default(dbgenerated("gen_random_uuid()")) @map("reference_id") @db.Uuid
  userId         String?   @map("user_id") @db.Uuid
  cdnImagePrefix String?   @map("cdn_image_prefix") @db.Text
  storageKey     String    @map("storage_key") @db.Text
  mimeType       String?   @map("mime_type") @db.VarChar(100)
  width          Int?
  height         Int?
  status         String    @default("uploaded") @db.VarChar(50)
  safetyStatus   String    @default("pending") @map("safety_status") @db.VarChar(50)
  safetyResult   Json?     @map("safety_result")
  createdAt      DateTime? @default(now()) @map("created_at") @db.Timestamptz(6)
  deleted        Int       @default(0)

  @@index([userId, createdAt], map: "idx_reference_images_user_created_at")
  @@map("reference_images")
  @@schema("monica_ai")
}

model GenerationJob {
  id               BigInt    @id @default(autoincrement())
  jobId            String    @unique @default(dbgenerated("gen_random_uuid()")) @map("job_id") @db.Uuid
  userId           String    @map("user_id") @db.Uuid
  themeId          BigInt?   @map("theme_id")
  referenceId      String?   @map("reference_id") @db.Uuid
  status           String    @default("pending") @db.VarChar(50)
  generationType   String    @default("text_to_image") @map("generation_type") @db.VarChar(50)
  prompt           String    @db.Text
  negativePrompt   String?   @map("negative_prompt") @db.Text
  model            String    @db.VarChar(100)
  style            String?   @db.VarChar(100)
  ratio            String?   @db.VarChar(50)
  imageCount       Int       @default(1) @map("image_count")
  estimatedCredits Int       @default(0) @map("estimated_credits")
  chargedCredits   Int       @default(0) @map("charged_credits")
  failureCode      String?   @map("failure_code") @db.VarChar(100)
  failureMessage   String?   @map("failure_message") @db.Text
  startedAt        DateTime? @map("started_at") @db.Timestamptz(6)
  completedAt      DateTime? @map("completed_at") @db.Timestamptz(6)
  createdAt        DateTime? @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime? @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  deleted          Int       @default(0)

  @@index([userId, createdAt], map: "idx_generation_jobs_user_created_at")
  @@index([status, createdAt], map: "idx_generation_jobs_status_created_at")
  @@index([themeId], map: "idx_generation_jobs_theme_id")
  @@map("generation_jobs")
  @@schema("monica_ai")
}

model GeneratedImage {
  id                 BigInt    @id @default(autoincrement())
  imageId            String    @unique @default(dbgenerated("gen_random_uuid()")) @map("image_id") @db.Uuid
  jobId              String?   @map("job_id") @db.Uuid
  providerImageIndex Int?      @map("provider_image_index")
  userId             String    @map("user_id") @db.Uuid
  imageType          String    @default("ai_generated") @map("image_type") @db.VarChar(50)
  status             String    @default("generated") @db.VarChar(50)
  isLocked           Boolean   @default(false) @map("is_locked")
  sourceImageUrl     String?   @map("source_image_url") @db.Text
  cdnImagePrefix     String?   @map("cdn_image_prefix") @db.Text
  storageKey         String?   @map("storage_key") @db.Text
  width              Int?
  height             Int?
  safetyStatus       String    @default("pending") @map("safety_status") @db.VarChar(50)
  safetyResult       Json?     @map("safety_result")
  metadata           Json?
  createdAt          DateTime? @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt          DateTime? @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  deleted            Int       @default(0)

  @@unique([jobId, providerImageIndex], map: "generated_images_job_provider_index_key")
  @@index([userId, createdAt], map: "idx_generated_images_user_created_at")
  @@index([status, createdAt], map: "idx_generated_images_status_created_at")
  @@map("generated_images")
  @@schema("monica_ai")
}

model ImageSubmission {
  id             BigInt    @id @default(autoincrement())
  userId         String    @map("user_id") @db.Uuid
  imageId        String    @map("image_id") @db.Uuid
  themeId        BigInt    @map("theme_id")
  status         String    @default("submitted") @db.VarChar(50)
  title          String    @db.VarChar(255)
  promptSnapshot String?   @map("prompt_snapshot") @db.Text
  creationNote   String?   @map("creation_note") @db.Text
  reviewFlow     Json?     @map("review_flow")
  submittedAt    DateTime? @default(now()) @map("submitted_at") @db.Timestamptz(6)
  createdAt      DateTime? @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime? @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  deleted        Int       @default(0)

  @@index([userId, submittedAt], map: "idx_image_submissions_user_submitted_at")
  @@index([themeId, status], map: "idx_image_submissions_theme_status")
  @@index([imageId], map: "idx_image_submissions_image_id")
  @@map("image_submissions")
  @@schema("monica_ai")
}

model PublicImage {
  id                 BigInt    @id @default(autoincrement())
  publicImageId      String    @unique @default(dbgenerated("gen_random_uuid()")) @map("public_image_id") @db.Uuid
  imageId            String    @unique @map("image_id") @db.Uuid
  sourceSubmissionId BigInt?   @unique @map("source_submission_id")
  userId             String    @map("user_id") @db.Uuid
  themeId            BigInt?   @map("theme_id")
  title              String    @db.VarChar(255)
  altText            String?   @map("alt_text") @db.Text
  creationNote       String?   @map("creation_note") @db.Text
  promptPublic       Boolean   @default(true) @map("prompt_public")
  tags               Json?
  likeCount          Int       @default(0) @map("like_count")
  saveCount          Int       @default(0) @map("save_count")
  viewCount          Int       @default(0) @map("view_count")
  uniqueViewCount    Int       @default(0) @map("unique_view_count")
  featuredScore      Int       @default(0) @map("featured_score")
  publishedAt        DateTime? @default(now()) @map("published_at") @db.Timestamptz(6)
  createdAt          DateTime? @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt          DateTime? @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  deleted            Int       @default(0)

  @@index([publishedAt], map: "idx_public_images_published_at")
  @@index([themeId, featuredScore], map: "idx_public_images_theme_featured_score")
  @@index([likeCount], map: "idx_public_images_like_count")
  @@map("public_images")
  @@schema("monica_ai")
}

model ImageLike {
  id            BigInt    @id @default(autoincrement())
  publicImageId String    @map("public_image_id") @db.Uuid
  userId        String    @map("user_id") @db.Uuid
  createdAt     DateTime? @default(now()) @map("created_at") @db.Timestamptz(6)
  deleted       Int       @default(0)

  @@unique([publicImageId, userId], map: "image_likes_public_image_user_key")
  @@index([userId, createdAt], map: "idx_image_likes_user_created_at")
  @@map("image_likes")
  @@schema("monica_ai")
}

model ImageSave {
  id            BigInt    @id @default(autoincrement())
  publicImageId String    @map("public_image_id") @db.Uuid
  userId        String    @map("user_id") @db.Uuid
  createdAt     DateTime? @default(now()) @map("created_at") @db.Timestamptz(6)
  deleted       Int       @default(0)

  @@unique([publicImageId, userId], map: "image_saves_public_image_user_key")
  @@index([userId, createdAt], map: "idx_image_saves_user_created_at")
  @@map("image_saves")
  @@schema("monica_ai")
}
